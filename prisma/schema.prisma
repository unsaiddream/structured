generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Syllabus {
  id          String   @id @default(cuid())
  fileName    String
  fileSize    Int
  subject     String
  courseCode  String?
  professor   String?
  semester    String?
  year        Int?
  rawText     String
  structured  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deadlines   Deadline[]
  grades      GradeItem[]
}

model Deadline {
  id          String   @id @default(cuid())
  syllabusId  String
  title       String
  date        DateTime?
  dateText    String?
  type        String
  description String?
  weight      Float?
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
}

model GradeItem {
  id          String   @id @default(cuid())
  syllabusId  String
  title       String
  weight      Float
  description String?
  syllabus    Syllabus @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
}
